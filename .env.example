# AskAHuman API endpoint
ASKAHUMAN_API_URL=https://api.askahuman.online

# LND connection (required for Lightning payments)
LND_REST_URL=https://localhost:8080
LND_MACAROON_HEX=<admin macaroon hex>

# LND TLS certificate path (optional — needed for self-signed certs on local LND nodes)
# LND_TLS_CERT_PATH=/path/to/tls.cert

# Log level (optional, default: info)
# LOG_LEVEL=info

# Agent identity for attribution and rate limiting on the server (optional)
# Defaults to "askahuman-mcp-agent" — set a unique ID per deployment to track usage separately
# ASKAHUMAN_AGENT_ID=my-agent
